{
  "name": "Claude Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--cap-drop=ALL",
    "--cap-add=SYS_PTRACE",
    "--security-opt=no-new-privileges",
    "--security-opt=seccomp=${localWorkspaceFolder}/.devcontainer/seccomp.json"
  ],
  "workspaceMount": "",
  "workspaceFolder": "/workspaces/project",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "C_Cpp.default.compilerPath": "/usr/bin/clang",
        "C_Cpp.default.cStandard": "c17",
        "C_Cpp.default.cppStandard": "c++17",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-vscode.cpptools",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-python.python"
      ]
    }
  },
  "mounts": [
    "source=claude-dev-sccache,target=/.sccache,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer,target=/workspaces/config/.devcontainer,type=bind,readonly",
    "source=${localWorkspaceFolder}/container-claude,target=/workspaces/config/container-claude,type=bind,readonly",
    "source=${localEnv:PROJECT_DIR},target=/workspaces/project,type=bind"
  ],
  "containerEnv": {
    "CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS": "true"
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "initializeCommand": "bash -c 'printf \"%s\\n%s\\n\" \"$(git config user.name 2>/dev/null)\" \"$(git config user.email 2>/dev/null)\" > \"${PROJECT_DIR}/.host-git-identity\"'",
  "postCreateCommand": "bash /workspaces/config/.devcontainer/post-create.sh",
  "remoteUser": "vscode"
}
